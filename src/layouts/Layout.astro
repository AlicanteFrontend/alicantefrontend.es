---
import '../styles/global.css';
import { Schema } from 'astro-seo-schema';
import type { Graph } from 'schema-dts';

interface Props {
	title?: string;
}

const { title = 'Alicante Frontend' } = Astro.props;

const siteUrl = 'https://alicantefrontend.es';
const description =
	'El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto.';

const jsonLd: Graph = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${siteUrl}/#organization`,
			name: 'Alicante Frontend',
			url: `${siteUrl}/`,
			logo: `${siteUrl}/alicante-frontend-logo.svg`,
			image: `${siteUrl}/og.png`,
			description,
			email: 'alicante.frontend@gmail.com',
			foundingDate: '2017-10-02',
			sameAs: [
				'https://x.com/AlicanteFront',
				'https://www.youtube.com/AlicanteFrontend',
				'https://www.meetup.com/es-ES/Alicante-Frontend',
			],
			location: {
				'@type': 'Place',
				name: 'Alicante',
				address: {
					'@type': 'PostalAddress',
					addressLocality: 'Alicante',
					addressRegion: 'Comunidad Valenciana',
					addressCountry: 'ES',
				},
			},
		},
		{
			'@type': 'WebSite',
			'@id': `${siteUrl}/#website`,
			url: `${siteUrl}/`,
			name: 'Alicante Frontend',
			description,
			inLanguage: 'es-ES',
			publisher: { '@id': `${siteUrl}/#organization` },
		},
		{
			'@type': 'EventSeries',
			'@id': `${siteUrl}/#event-series`,
			name: 'Alicante Frontend Meetups',
			description: 'Meetup mensual sobre desarrollo web frontend en Alicante.',
			url: `${siteUrl}/`,
			image: `${siteUrl}/og.png`,
			startDate: '2017-10-02',
			inLanguage: 'es-ES',
			organizer: { '@id': `${siteUrl}/#organization` },
			location: {
				'@type': 'Place',
				name: 'Alicante',
				address: {
					'@type': 'PostalAddress',
					addressLocality: 'Alicante',
					addressRegion: 'Comunidad Valenciana',
					addressCountry: 'ES',
				},
			},
			eventSchedule: {
				'@type': 'Schedule',
				repeatFrequency: 'P1M',
			},
		},
	],
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="X-UA-Compatible" content="ie=edge" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#3a84d0" />
		<title>{title}</title>
		<meta
			name="description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta itemprop="name" content="Alicante Frontend" />
		<meta
			itemprop="description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta itemprop="image" content="/og.png" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:site" content="@AlicanteFront" />
		<meta name="twitter:creator" content="@AlicanteFront" />
		<meta name="twitter:image" content="/og.png" />
		<meta name="twitter:image:alt" content="Alicante Frontend Logo" />
		<meta property="og:site_name" content="Alicante Frontend" />
		<meta property="og:url" content="https://www.alicantefrontend.es/" />
		<meta property="og:title" content="Alicante Frontend" />
		<meta
			property="og:description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta property="og:image" content="/og.png" />
		<meta property="og:locale" content="es_ES" />

		<script src="https://cdn.usefathom.com/script.js" data-site="FRZKPXBX" defer></script>
		<Schema item={jsonLd} />
	</head>
	<body>
		<slot />
	</body>
</html>
