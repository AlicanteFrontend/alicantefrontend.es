---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Alicante Frontend' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="X-UA-Compatible" content="ie=edge" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#3a84d0" />
		<title>{title}</title>
		<meta
			name="description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta itemprop="name" content="Alicante Frontend" />
		<meta
			itemprop="description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta itemprop="image" content="/og.png" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:site" content="@AlicanteFront" />
		<meta name="twitter:creator" content="@AlicanteFront" />
		<meta name="twitter:image" content="/og.png" />
		<meta name="twitter:image:alt" content="Alicante Frontend Logo" />
		<meta property="og:site_name" content="Alicante Frontend" />
		<meta property="og:url" content="https://www.alicantefrontend.es/" />
		<meta property="og:title" content="Alicante Frontend" />
		<meta
			property="og:description"
			content="El ecosistema Frontend es un caos y ¡nos encanta! Si quieres aprender y compartir sobre desarrollo web orientado al Frontend has llegado al sitio correcto."
		/>
		<meta property="og:image" content="/og.png" />
		<meta property="og:locale" content="es_ES" />
	</head>
	<body>
		<slot />
	</body>
</html>
